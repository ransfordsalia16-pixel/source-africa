# SOURCE AFRICA uses one .env file per service, not one shared file, because the frontend's
# variables are VITE_-prefixed and get compiled straight into the browser bundle — anything in
# frontend/.env is effectively public. Backend secrets must never end up there.
#
# Copy each file below and fill in real values for your machine:
#   frontend/.env.example -> frontend/.env
#   backend/.env.example  -> backend/.env
#
# This root file only documents the two, for placeholders only. Do not put real secrets here.

# --- frontend/.env ---
# VITE_API_BASE_URL=http://localhost:4000

# --- backend/.env ---
# PORT=4000
# DATABASE_PATH=./data/sourcebridge.sqlite
# JWT_SECRET=replace-with-a-long-random-value
# JWT_EXPIRES_IN=12h
# WEBHOOK_SECRET=replace-with-a-long-random-value
# MFA_ENCRYPTION_KEY=replace-with-a-64-character-hex-value
# CORS_ORIGIN=http://localhost:5505
# DEMO_BUYER_PASSWORD=replace-for-local-dev-only
# DEMO_SUPPLIER_PASSWORD=replace-for-local-dev-only
# DEMO_ADMIN_PASSWORD=replace-for-local-dev-only
